<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Launcher.App.ViewModels"
        x:Class="Launcher.App.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{DynamicResource BrandServerName}"
        Icon="avares://Launcher.App/Assets/icon.ico"
        Width="{DynamicResource WindowWidth}"
        Height="{DynamicResource WindowHeight}"
        CanResize="False"
        WindowDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        WindowStartupLocation="CenterScreen">

    <Window.Styles>
        <!-- Progress bar in brand gold over a dark track. -->
        <Style Selector="ProgressBar">
            <Setter Property="Foreground" Value="{DynamicResource BrandAccentBrush}" />
            <Setter Property="Background" Value="#55000000" />
            <Setter Property="Height" Value="14" />
            <Setter Property="MinHeight" Value="14" />
            <Setter Property="CornerRadius" Value="7" />
        </Style>

        <!-- PLAY button: gold gradient, dark label. -->
        <Style Selector="Button.play">
            <Setter Property="Background" Value="{DynamicResource BrandAccentBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource BrandButtonTextBrush}" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="24,10" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.play:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource BrandGoldHighlightBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource BrandButtonTextBrush}" />
        </Style>
        <Style Selector="Button.play:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="#55A68A2D" />
            <Setter Property="Foreground" Value="#88E0E0E0" />
        </Style>

        <!-- Retry button: ghost outline in gold. -->
        <Style Selector="Button.ghost">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrandGoldBrush}" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="Foreground" Value="{DynamicResource BrandGoldBrush}" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="18,10" />
        </Style>
        <Style Selector="Button.ghost:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#22D4AF37" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrandGoldBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource BrandGoldHighlightBrush}" />
        </Style>

        <!-- Window caption buttons (minimise / close) drawn in gold. -->
        <Style Selector="Button.caption">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.caption:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#33D4AF37" />
        </Style>
        <Style Selector="Button.caption.close:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#66C0392B" />
        </Style>
    </Window.Styles>

    <!-- Rounded gold frame; clips the artwork to the corners. -->
    <Panel>
        <!-- Background + content; clipped so the artwork can't spill outward. -->
        <Border CornerRadius="{DynamicResource WindowCornerRadius}"
                Background="{DynamicResource BrandWindowBrush}"
                ClipToBounds="True">
            <Panel ClipToBounds="True">
            <!-- Background art (swap Assets/background.jpg to rebrand).
                 Nudged vertically by BackgroundOffsetY; any strip left uncovered
                 at the bottom sits behind the opaque panel. -->
            <Image Source="avares://Launcher.App/Assets/background.jpg" Stretch="UniformToFill">
                <Image.RenderTransform>
                    <TranslateTransform Y="{DynamicResource BackgroundOffsetY}" />
                </Image.RenderTransform>
            </Image>

            <!-- Light overall dim so the artwork isn't too loud (BrandArtDimColor). -->
            <Border Background="{DynamicResource BrandArtDimBrush}" />

            <Grid RowDefinitions="Auto,*,Auto">

                <!-- Title bar (drag handle). Content depends on BrandTitleMode:
                     Text = name + subtitle, Logo = Assets/logo.png, None = bare
                     background. All three stay in the XAML; visibility is bound, so
                     switching modes is a one-line branding change, not surgery.
                     The overlays are non-hit-test so the whole strip stays draggable. -->
                <Panel Grid.Row="0">
                    <Border Name="TitleBar" Background="Transparent" MinHeight="64"
                            PointerPressed="OnTitleBarPressed">
                        <Panel>
                            <Border Background="{DynamicResource BrandTitleScrimBrush}"
                                    IsVisible="{Binding ShowTitleArea}" IsHitTestVisible="False" />

                            <StackPanel IsVisible="{Binding ShowTextTitle}" IsHitTestVisible="False"
                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Margin="0,52,0,30" Spacing="2">
                                <TextBlock Text="{DynamicResource BrandServerName}"
                                           Foreground="{DynamicResource BrandGoldBrush}"
                                           FontSize="34" FontWeight="Bold" LetterSpacing="6"
                                           HorizontalAlignment="Center">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#FF000000" BlurRadius="10" OffsetX="0" OffsetY="1" />
                                    </TextBlock.Effect>
                                </TextBlock>
                                <TextBlock Text="{DynamicResource BrandSubtitle}"
                                           Foreground="{DynamicResource BrandTextDimBrush}"
                                           FontSize="14" LetterSpacing="5"
                                           HorizontalAlignment="Center" />
                            </StackPanel>

                            <Image IsVisible="{Binding ShowLogo}" IsHitTestVisible="False"
                                   Source="avares://Launcher.App/Assets/logo.png"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Margin="0,44,0,26" MaxHeight="84" Stretch="Uniform" />
                        </Panel>
                    </Border>

                    <!-- Settings (gear): top-left, same level as the caption buttons. -->
                    <Button Classes="caption" Command="{Binding OpenSettingsCommand}"
                            HorizontalAlignment="Left" VerticalAlignment="Top" Margin="8,6,0,0"
                            ToolTip.Tip="{DynamicResource UiSettings}">
                        <Path Fill="{DynamicResource BrandGoldBrush}" Width="13" Height="13" Stretch="Uniform"
                              Data="M19.14,12.94c0.04-0.3,0.06-0.61,0.06-0.94c0-0.32-0.02-0.64-0.07-0.94l2.03-1.58c0.18-0.14,0.23-0.41,0.12-0.61l-1.92-3.32c-0.12-0.22-0.37-0.29-0.59-0.22l-2.39,0.96c-0.5-0.38-1.03-0.7-1.62-0.94L14.4,2.81c-0.04-0.24-0.24-0.41-0.48-0.41h-3.84c-0.24,0-0.43,0.17-0.47,0.41L9.25,5.35C8.66,5.59,8.12,5.92,7.63,6.29L5.24,5.33c-0.22-0.08-0.47,0-0.59,0.22L2.74,8.87c-0.12,0.21-0.08,0.47,0.12,0.61l2.03,1.58C4.84,11.36,4.8,11.69,4.8,12s0.02,0.64,0.07,0.94l-2.03,1.58c-0.18,0.14-0.23,0.41-0.12,0.61l1.92,3.32c0.12,0.22,0.37,0.29,0.59,0.22l2.39-0.96c0.5,0.38,1.03,0.7,1.62,0.94l0.36,2.54c0.05,0.24,0.24,0.41,0.48,0.41h3.84c0.24,0,0.44-0.17,0.47-0.41l0.36-2.54c0.59-0.24,1.13-0.56,1.62-0.94l2.39,0.96c0.22,0.08,0.47,0,0.59-0.22l1.92-3.32c0.12-0.22,0.07-0.47-0.12-0.61L19.14,12.94z M12,15.6c-1.98,0-3.6-1.62-3.6-3.6s1.62-3.6,3.6-3.6s3.6,1.62,3.6,3.6S13.98,15.6,12,15.6z" />
                    </Button>

                    <StackPanel Orientation="Horizontal" Spacing="2"
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                Margin="0,6,8,0">
                        <Button Classes="caption" Click="OnMinimise" ToolTip.Tip="{DynamicResource UiMinimise}">
                            <Path Stroke="{DynamicResource BrandGoldBrush}" StrokeThickness="1.6"
                                  Data="M0,0 L12,0" />
                        </Button>
                        <Button Classes="caption close" Click="OnClose" ToolTip.Tip="{DynamicResource UiClose}">
                            <Path Stroke="{DynamicResource BrandGoldBrush}" StrokeThickness="1.6"
                                  Data="M0,0 L11,11 M0,11 L11,0" />
                        </Button>
                    </StackPanel>
                </Panel>

                <!-- Row 1 is empty so the artwork shows through. -->

                <!-- Bottom panel: status, progress, actions. -->
                <Border Grid.Row="2"
                        Background="{DynamicResource BrandPanelBrush}"
                        BorderBrush="{DynamicResource BrandGoldBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="28,15,28,23">
                    <StackPanel Spacing="9">
                        <TextBlock Text="{Binding StatusText}"
                                   Foreground="{DynamicResource BrandTextBrush}"
                                   TextWrapping="Wrap" />
                        <ProgressBar Minimum="0" Maximum="100"
                                     Value="{Binding ProgressValue}"
                                     IsIndeterminate="{Binding IsProgressIndeterminate}" />
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right" Spacing="12"
                                    Margin="0,9,0,0">
                            <Button Classes="ghost" Content="{DynamicResource UiRetry}"
                                    Command="{Binding RetryCommand}"
                                    IsVisible="{Binding CanRetry}" />
                            <Button Classes="play" Content="{DynamicResource UiPlay}"
                                    Command="{Binding PlayCommand}"
                                    IsEnabled="{Binding CanPlay}"
                                    Width="150" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Panel>
        </Border>

        <!-- Settings overlay: dims the window and shows the client settings panel. -->
        <Border IsVisible="{Binding IsSettingsOpen}" Background="#CC000000">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center" Width="430"
                    Background="{DynamicResource BrandPanelBrush}"
                    BorderBrush="{DynamicResource BrandGoldBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="30,24">
                <StackPanel Spacing="18" DataContext="{Binding Settings}">
                    <TextBlock Text="{DynamicResource UiSettings}"
                               Foreground="{DynamicResource BrandGoldBrush}"
                               FontSize="20" FontWeight="Bold" LetterSpacing="3"
                               HorizontalAlignment="Center" />

                    <StackPanel Spacing="14">
                        <Grid ColumnDefinitions="130,*" VerticalAlignment="Center">
                            <TextBlock Grid.Column="0" Text="{DynamicResource UiResolution}"
                                       Foreground="{DynamicResource BrandTextBrush}" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                      ItemsSource="{Binding Resolutions}"
                                      SelectedItem="{Binding Resolution}" />
                        </Grid>

                        <Grid ColumnDefinitions="130,*" VerticalAlignment="Center">
                            <TextBlock Grid.Column="0" Text="{DynamicResource UiWindowed}"
                                       Foreground="{DynamicResource BrandTextBrush}" VerticalAlignment="Center" />
                            <CheckBox Grid.Column="1" IsChecked="{Binding Windowed}" />
                        </Grid>

                        <Grid ColumnDefinitions="130,*,32" VerticalAlignment="Center">
                            <TextBlock Grid.Column="0" Text="{DynamicResource UiSound}"
                                       Foreground="{DynamicResource BrandTextBrush}" VerticalAlignment="Center" />
                            <Slider Grid.Column="1" Minimum="{Binding MinVolume}" Maximum="{Binding MaxVolume}"
                                    TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding SoundVolume}" />
                            <TextBlock Grid.Column="2" Text="{Binding SoundVolume}"
                                       Foreground="{DynamicResource BrandTextBrush}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center" />
                        </Grid>

                        <Grid ColumnDefinitions="130,*,32" VerticalAlignment="Center">
                            <TextBlock Grid.Column="0" Text="{DynamicResource UiMusic}"
                                       Foreground="{DynamicResource BrandTextBrush}" VerticalAlignment="Center" />
                            <Slider Grid.Column="1" Minimum="{Binding MinVolume}" Maximum="{Binding MaxVolume}"
                                    TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding MusicVolume}" />
                            <TextBlock Grid.Column="2" Text="{Binding MusicVolume}"
                                       Foreground="{DynamicResource BrandTextBrush}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12" Margin="0,4,0,0">
                        <Button Classes="ghost" Content="{DynamicResource UiCancel}" Command="{Binding CancelCommand}" />
                        <Button Classes="play" Content="{DynamicResource UiSave}" Command="{Binding SaveCommand}" Width="120" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <!-- Gold frame painted last, so it always sits on top of the background
             art - whatever image is dropped into Assets/ can never cover it.
             Non-interactive so it doesn't block dragging or the caption buttons. -->
        <Border CornerRadius="{DynamicResource WindowCornerRadius}"
                BorderBrush="{DynamicResource BrandGoldBrush}"
                BorderThickness="{DynamicResource WindowBorderThickness}"
                IsHitTestVisible="False" />
    </Panel>
</Window>
